{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}OPTIC{% endblock %}</title>

  <link rel="stylesheet" href="/css/app.css">

  <link rel="stylesheet" href="/css/components/button.css">
  <link rel="stylesheet" href="/css/components/navbar.css">

  {% block stylesheets %}{% endblock %}
  {% block javascripts %}{% endblock %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
</head>

<body class="{% block body_class %}{% endblock %}">

{% block header %}
  <twig:Navbar
    brandHref="{{ path('app_home') }}"
    brandLabel="OPTIC"
    brandIcon="uit:calendar"
    homeHref="{{ path('app_home') }}"
    searchHref="{{ path('app_store_search') }}"
    loginHref="{{ path('app_login') }}"
    registerHref="{{ path('app_registration') }}"
    accountLabel="Mon compte"
    loginLabel="Connexion"
    registerLabel="S'inscrire"
    userIcon="uil:user"
  />
{% endblock %}

<main class="main" role="main">
  {% set successFlashes = app.flashes('success') %}
  {% set errorFlashes = app.flashes('error') %}
  {% set infoFlashes = app.flashes('info') %}
  {% set warningFlashes = app.flashes('warning') %}

  {% if successFlashes or errorFlashes or infoFlashes or warningFlashes %}
    <div class="flash-toast-stack" data-controller="flash-toast" aria-live="polite" aria-atomic="true">
      {% for message in successFlashes %}
        <article class="flash-toast flash-toast--success" role="status" data-flash-toast-target="item">
          <button class="flash-toast__close"
                  type="button"
                  aria-label="Fermer la notification"
                  data-action="flash-toast#close">
            {{ ux_icon('uil:times') }}
          </button>
          <div class="flash-toast__icon" aria-hidden="true">
            {{ ux_icon('uil:check') }}
          </div>
          <p class="flash-toast__message">{{ message }}</p>
        </article>
      {% endfor %}

      {% for message in infoFlashes %}
        <article class="flash-toast flash-toast--info" role="status" data-flash-toast-target="item">
          <button class="flash-toast__close"
                  type="button"
                  aria-label="Fermer la notification"
                  data-action="flash-toast#close">
            {{ ux_icon('uil:times') }}
          </button>
          <div class="flash-toast__icon" aria-hidden="true">
            {{ ux_icon('uil:info-circle') }}
          </div>
          <p class="flash-toast__message">{{ message }}</p>
        </article>
      {% endfor %}

      {% for message in warningFlashes %}
        <article class="flash-toast flash-toast--warning" role="alert" data-flash-toast-target="item">
          <button class="flash-toast__close"
                  type="button"
                  aria-label="Fermer la notification"
                  data-action="flash-toast#close">
            {{ ux_icon('uil:times') }}
          </button>
          <div class="flash-toast__icon" aria-hidden="true">
            {{ ux_icon('uil:exclamation-circle') }}
          </div>
          <p class="flash-toast__message">{{ message }}</p>
        </article>
      {% endfor %}

      {% for message in errorFlashes %}
        <article class="flash-toast flash-toast--error" role="alert" data-flash-toast-target="item">
          <button class="flash-toast__close"
                  type="button"
                  aria-label="Fermer la notification"
                  data-action="flash-toast#close">
            {{ ux_icon('uil:times') }}
          </button>
          <div class="flash-toast__icon" aria-hidden="true">
            {{ ux_icon('uil:times-circle') }}
          </div>
          <p class="flash-toast__message">{{ message }}</p>
        </article>
      {% endfor %}
    </div>
  {% endif %}

  {% block body %}{% endblock %}
</main>

{% block footer %}{% endblock %}
</body>
</html>
