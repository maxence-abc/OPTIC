{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}OPTIC{% endblock %}</title>

  <link rel="stylesheet" href="/css/app.css">

  <link rel="stylesheet" href="/css/components/button.css">
  <link rel="stylesheet" href="/css/components/navbar.css">

  {% block stylesheets %}{% endblock %}
  {% block javascripts %}{% endblock %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
</head>

<body class="{% block body_class %}{% endblock %}">

{% block header %}
  <twig:Navbar
    brandHref="{{ path('app_home') }}"
    brandLabel="OPTIC"
    brandIcon="uit:calendar"
    homeHref="{{ path('app_home') }}"
    searchHref="{{ path('app_store_search') }}"
    loginHref="{{ path('app_login') }}"
    registerHref="{{ path('app_registration') }}"
    accountLabel="Mon compte"
    loginLabel="Connexion"
    registerLabel="S'inscrire"
    userIcon="uil:user"
  />
{% endblock %}

<main class="main" role="main">
  {% set successFlashes = app.flashes('success') %}
  {% set errorFlashes = app.flashes('error') %}
  {% set infoFlashes = app.flashes('info') %}
  {% set warningFlashes = app.flashes('warning') %}

  {% if successFlashes or errorFlashes or infoFlashes or warningFlashes %}
    <div class="flash-toast-stack" data-controller="flash-toast" aria-live="polite" aria-atomic="true">
      {% for message in successFlashes %}
        <article class="flash-toast flash-toast--success" role="status" data-flash-toast-target="item">
          <button class="flash-toast__close"
                  type="button"
                  aria-label="Fermer la notification"
                  data-action="flash-toast#close">
            {{ ux_icon('uil:times') }}
          </button>
          <div class="flash-toast__icon" aria-hidden="true">
            {{ ux_icon('uil:check') }}
          </div>
          <p class="flash-toast__message">{{ message }}</p>
        </article>
      {% endfor %}

      {% for message in infoFlashes %}
        <article class="flash-toast flash-toast--info" role="status" data-flash-toast-target="item">
          <button class="flash-toast__close"
                  type="button"
                  aria-label="Fermer la notification"
                  data-action="flash-toast#close">
            {{ ux_icon('uil:times') }}
          </button>
          <div class="flash-toast__icon" aria-hidden="true">
            {{ ux_icon('uil:info-circle') }}
          </div>
          <p class="flash-toast__message">{{ message }}</p>
        </article>
      {% endfor %}

      {% for message in warningFlashes %}
        <article class="flash-toast flash-toast--warning" role="alert" data-flash-toast-target="item">
          <button class="flash-toast__close"
                  type="button"
                  aria-label="Fermer la notification"
                  data-action="flash-toast#close">
            {{ ux_icon('uil:times') }}
          </button>
          <div class="flash-toast__icon" aria-hidden="true">
            {{ ux_icon('uil:exclamation-circle') }}
          </div>
          <p class="flash-toast__message">{{ message }}</p>
        </article>
      {% endfor %}

      {% for message in errorFlashes %}
        <article class="flash-toast flash-toast--error" role="alert" data-flash-toast-target="item">
          <button class="flash-toast__close"
                  type="button"
                  aria-label="Fermer la notification"
                  data-action="flash-toast#close">
            {{ ux_icon('uil:times') }}
          </button>
          <div class="flash-toast__icon" aria-hidden="true">
            {{ ux_icon('uil:times-circle') }}
          </div>
          <p class="flash-toast__message">{{ message }}</p>
        </article>
      {% endfor %}
    </div>
  {% endif %}

  {% block body %}{% endblock %}
</main>

{% block footer %}
  <footer class="site-footer" role="contentinfo">
    <div class="container container--wide site-footer__inner">
      <span class="site-footer__legal">Mentions légales</span>

      <div class="site-footer__socials" aria-label="Réseaux sociaux">
        <span class="site-footer__social" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.4 3.5 12 3.5 12 3.5s-7.4 0-9.4.6A3 3 0 0 0 .5 6.2 31.7 31.7 0 0 0 0 12a31.7 31.7 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c2 .6 9.4.6 9.4.6s7.4 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.7 31.7 0 0 0 24 12a31.7 31.7 0 0 0-.5-5.8ZM9.6 15.8V8.2l6.6 3.8-6.6 3.8Z"/>
          </svg>
        </span>

        <span class="site-footer__social" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.6 1.7-1.6h1.5V4.8c-.3 0-1.2-.1-2.3-.1-2.3 0-3.8 1.4-3.8 4V11H8v3h2.6v8h2.9Z"/>
          </svg>
        </span>

        <span class="site-footer__social" aria-label="Twitter">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M21.5 7.1c-.7.3-1.5.5-2.3.6a4 4 0 0 0 1.8-2.2c-.8.5-1.7.8-2.7 1A4 4 0 0 0 11.5 10a11.3 11.3 0 0 1-8.2-4.2 4 4 0 0 0 1.2 5.4c-.7 0-1.3-.2-1.9-.5v.1a4 4 0 0 0 3.2 3.9c-.3.1-.7.1-1 .1-.2 0-.5 0-.8-.1a4 4 0 0 0 3.8 2.8A8 8 0 0 1 2 19.2 11.2 11.2 0 0 0 8.1 21c7.2 0 11.2-6 11.2-11.2v-.5c.8-.5 1.5-1.2 2.2-2.1Z"/>
          </svg>
        </span>

        <span class="site-footer__social" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2Zm0 1.8A3.7 3.7 0 0 0 3.8 7.5v9a3.7 3.7 0 0 0 3.7 3.7h9a3.7 3.7 0 0 0 3.7-3.7v-9a3.7 3.7 0 0 0-3.7-3.7h-9Zm9.7 1.4a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.8A3.2 3.2 0 1 0 12 15.2 3.2 3.2 0 0 0 12 8.8Z"/>
          </svg>
        </span>

        <span class="site-footer__social" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.4 8.3a1.9 1.9 0 1 1 0-3.8 1.9 1.9 0 0 1 0 3.8ZM4.8 9.8H8v9.4H4.8V9.8Zm5.2 0h3v1.3h.1c.4-.8 1.5-1.7 3.1-1.7 3.3 0 3.9 2.1 3.9 4.9v4.9H17v-4.4c0-1.1 0-2.5-1.6-2.5s-1.8 1.2-1.8 2.4v4.5h-3.2V9.8Z"/>
          </svg>
        </span>
      </div>

      <span class="site-footer__spacer" aria-hidden="true"></span>
    </div>
  </footer>
{% endblock %}
</body>
</html>
