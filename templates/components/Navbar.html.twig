{% if this.enabled %}
<header
  class="navbar"
  data-controller="navbar"
  data-action="click@window->navbar#closeOnOutside keydown.esc@window->navbar#closeAll"
>
  <div class="container container--wide navbar__container">

    {# Brand #}
    <div class="navbar__brand">
      <a href="{{ this.brandHref ?? path('app_home') }}" class="navbar__logo">
        {% if this.brandIcon %}
          <span class="navbar__icon" aria-hidden="true">
            {{ ux_icon(this.brandIcon) }}
          </span>
        {% endif %}
        <span class="navbar__name">{{ this.brandLabel }}</span>
      </a>
    </div>

    {# Burger (mobile only) #}
    <button
      class="navbar__burger"
      type="button"
      aria-label="Ouvrir le menu"
      aria-controls="navbar-main-nav"
      aria-expanded="false"
      data-action="navbar#toggleNav"
      data-navbar-target="burgerButton"
    >
      <span class="navbar__burger-icon" aria-hidden="true">{{ ux_icon('uil:bars') }}</span>
    </button>

    {# Navigation #}
    <nav
      id="navbar-main-nav"
      class="navbar__nav"
      aria-label="Navigation principale"
      data-navbar-target="nav"
    >
      {% set hasAssignedEstablishment = app.user and app.user.establishment is not null %}
      {% set hasOwnedEstablishments = app.user and app.user.establishments|length > 0 %}
      {% set hasDirectProAccess = app.user and ('ROLE_PRO' in app.user.roles or 'ROLE_ADMIN_PRO' in app.user.roles) %}
      {% set isPlatformAdmin = app.user and 'ROLE_ADMIN' in app.user.roles %}
      {% set canAccessProSpace = app.user and (
        (hasDirectProAccess and (hasAssignedEstablishment or hasOwnedEstablishments))
        or (isPlatformAdmin and hasAssignedEstablishment)
      ) %}

      <a href="{{ this.homeHref ?? path('app_home') }}" class="navbar__link">Accueil</a>
      <a href="{{ this.searchHref ?? path('app_store_search') }}" class="navbar__link">Rechercher un service</a>

      {% if app.user and is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin') }}" class="navbar__link">Admin</a>
      {% elseif app.user and is_granted('ROLE_ADMIN_PRO') %}
        <a href="{{ path('app_manager_home') }}" class="navbar__link">Gestion</a>
      {% endif %}

      {% if canAccessProSpace %}
        <a href="{{ path('app_pro_dashboard') }}" class="navbar__link">Mon entreprise</a>
      {% endif %}
    </nav>

    {# User #}
    <div class="navbar__user">
      {% if app.user %}
        {% set reservationsHref = path('app_account', { tab: 'reservations' }) %}
        {% set reviewsHref = path('app_account', { tab: 'reviews' }) %}
        {% set settingsHref = path('app_account', { tab: 'profile' }) ~ '#account-settings' %}

        <div class="navbar__user-info">
          <div class="navbar__user-text">
            <span class="navbar__user-name">{{ app.user.firstName }} {{ app.user.lastName }}</span>
            <span class="navbar__email">{{ app.user.email }}</span>
          </div>

          <div class="navbar__account" data-navbar-target="accountContainer">
            <button
              class="navbar__account-trigger"
              type="button"
              aria-label="Ouvrir le menu Mon compte"
              aria-haspopup="menu"
              aria-controls="navbar-account-menu"
              aria-expanded="false"
              data-action="navbar#toggleAccount"
              data-navbar-target="accountButton"
            >
              <span class="navbar__account-trigger-icon" aria-hidden="true">{{ ux_icon(this.userIcon) }}</span>
              <span class="navbar__account-trigger-label">{{ this.accountLabel }}</span>
            </button>

            <div
              id="navbar-account-menu"
              class="navbar__account-menu"
              role="menu"
              hidden
              data-navbar-target="accountPanel"
            >
              <div class="navbar__account-section">
                <a href="{{ reservationsHref }}" class="navbar__account-link" role="menuitem">
                  <span class="navbar__account-link-icon" aria-hidden="true">{{ ux_icon('uil:bookmark') }}</span>
                  <span>Mes réservations</span>
                </a>

                <a href="{{ reviewsHref }}" class="navbar__account-link" role="menuitem">
                  <span class="navbar__account-link-icon" aria-hidden="true">{{ ux_icon('uil:star') }}</span>
                  <span>Mes avis</span>
                </a>

                <a href="{{ settingsHref }}" class="navbar__account-link" role="menuitem">
                  <span class="navbar__account-link-icon" aria-hidden="true">{{ ux_icon('uil:setting') }}</span>
                  <span>Paramètres</span>
                </a>
              </div>

              <div class="navbar__account-section">
                <a href="{{ path('app_logout') }}" class="navbar__account-link navbar__account-link--logout" role="menuitem">
                  <span class="navbar__account-link-icon" aria-hidden="true">{{ ux_icon('uil:signout') }}</span>
                  <span>Déconnexion</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      {% else %}
        <div class="navbar__user-info">
          <twig:Button
            label="{{ this.loginLabel }}"
            href="{{ this.loginHref ?? path('app_login') }}"
            variant="outline"
            size="md"
            iconLeft="{{ this.userIcon }}"
          />

          <twig:Button
            label="{{ this.registerLabel }}"
            href="{{ this.registerHref ?? path('app_registration') }}"
            variant="primary"
            size="md"
          />
        </div>
      {% endif %}
    </div>

  </div>
</header>
{% endif %}
