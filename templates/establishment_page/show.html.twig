{% extends 'base.html.twig' %}

{% block title %}{{ establishment.name }}{% endblock %}
{% block body_class %}page-establishment-show{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="/css/pages/establishments.css">
  <link rel="stylesheet" href="/css/pages/account.css">
  <link rel="stylesheet" href="/css/pages/establishment-show.css">
{% endblock %}

{% block body %}
  {# Back URL: si on vient de la recherche avec q/city/category, on reconstruit #}
  {% set backUrl = app.request.headers.get('referer') ?: path('app_store_search') %}
  {% set q = app.request.query.get('q') %}
  {% set city = app.request.query.get('city') %}
  {% set category = app.request.query.get('category') %}
  {% set bookingBaseParams = {
    id: establishment.id,
    q: q,
    city: city,
    category: category,
    _fragment: 'booking'
  } %}
  {% set serviceSelectionBaseParams = bookingBaseParams|merge({ _fragment: 'booking-schedule' }) %}
  {% set serviceListBaseParams = bookingBaseParams|merge({ _fragment: 'services' }) %}
  {% set reviewOpenParams = reviewableAppointment ? reviewBaseParams|merge({ review: reviewableAppointment.id }) : null %}
  {% if q or city or category %}
    {% set backUrl = path('app_store_search', { q: q, city: city, category: category }) %}
  {% endif %}
  {% set hasGallery = heroImages|length > 1 %}

  <div class="container container--wide est-show">

    <a class="est-back" href="{{ backUrl }}">
      <span class="est-back__icon" aria-hidden="true">{{ ux_icon('uil:arrow-left') }}</span>
      Retour aux résultats
    </a>

    <section class="est-card est-show__hero{% if hasGallery %} has-gallery{% endif %}"
             {% if hasGallery %}
               data-controller="carousel"
               data-carousel-interval-value="5000"
             {% endif %}>
      <div class="est-card__media">
        {% if hasGallery %}
          <div class="est-gallery__track" data-carousel-target="track">
            {% for imageSrc in heroImages %}
              <div class="est-gallery__slide">
                <img class="est-card__img"
                     src="{{ imageSrc }}"
                     alt="Photo {{ loop.index }} de {{ establishment.name }}"
                     loading="lazy">
              </div>
            {% endfor %}
          </div>

          <button class="est-gallery__nav est-gallery__nav--prev"
                  type="button"
                  aria-label="Photo précédente"
                  data-action="carousel#prev">
            {{ ux_icon('uil:angle-left-b') }}
          </button>

          <button class="est-gallery__nav est-gallery__nav--next"
                  type="button"
                  aria-label="Photo suivante"
                  data-action="carousel#next">
            {{ ux_icon('uil:angle-right-b') }}
          </button>

          <div class="est-gallery__dots">
            {% for imageSrc in heroImages %}
              <button class="est-gallery__dot{% if loop.first %} is-active{% endif %}"
                      type="button"
                      aria-label="Voir la photo {{ loop.index }}"
                      data-carousel-target="dot"
                      data-index="{{ loop.index0 }}"
                      data-action="carousel#goTo">
              </button>
            {% endfor %}
          </div>
        {% else %}
          <img class="est-card__img"
               src="{{ heroSrc }}"
               alt="Photo de {{ establishment.name }}"
               loading="lazy">
        {% endif %}
      </div>
      <div class="est-card__body">
        <h1 class="est-card__title">{{ establishment.name }}</h1>
        <p class="est-card__meta">
          <span class="est-card__pin">{{ ux_icon('uil:map-marker') }}</span>
          {{ establishment.address }}, {{ establishment.postalCode }} {{ establishment.city }}
        </p>
      </div>
    </section>

    <section class="account-card">
      <div class="account-card__header">
        <h2 class="account-card__title">À propos</h2>
      </div>
      <p class="est-text">
        {{ establishment.description ?: 'Aucune description pour le moment.' }}
      </p>
    </section>

    {# =========================
       SERVICES (désélection possible)
       ========================= #}
    <section class="account-card" id="services">
      <div class="account-card__header">
        <h2 class="account-card__title">Services proposés</h2>
      </div>

      {% if establishment.services|length == 0 %}
        <p class="est-muted">Aucun service pour le moment.</p>
      {% else %}
        <div class="est-services">
          {% for s in establishment.services %}
            {% set isActiveService = (selectedServiceId == s.id) %}

            <a class="est-service {{ isActiveService ? 'is-active' : '' }}"
               href="{{ path('front_establishment_show', isActiveService
                 ? serviceListBaseParams|merge({
                     week: weekStart|date('Y-m-d'),
                     date: selectedDateStr ?: null,
                     professional: selectedProfessionalId ?: null
                   })
                 : serviceSelectionBaseParams|merge({
                     service: s.id,
                     week: weekStart|date('Y-m-d'),
                     date: selectedDateStr ?: null,
                     professional: selectedProfessionalId ?: null
                   })
               ) }}">
              <div class="est-service__main">
                <div class="est-service__name">{{ s.name }}</div>
                <div class="est-service__sub">Durée : {{ s.duration }} min</div>
              </div>
              <div class="est-service__price">{{ s.price|number_format(2, ',', ' ') }} €</div>
            </a>
          {% endfor %}
        </div>

        <p class="est-hint">
          Clique un service pour afficher les créneaux. Clique à nouveau pour désélectionner.
        </p>
      {% endif %}
    </section>

    {# =========================
       HORAIRES
       ========================= #}
    <section class="account-card">
      <div class="account-card__header">
        <h2 class="account-card__title">Horaires d’ouverture</h2>
      </div>

      {% set days = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'] %}
      {% set labels = {'Monday':'Lundi','Tuesday':'Mardi','Wednesday':'Mercredi','Thursday':'Jeudi','Friday':'Vendredi','Saturday':'Samedi','Sunday':'Dimanche'} %}

      <div class="est-hours">
        {% for d in days %}
          {% set intervals = (establishment.openingHours|filter(x => x.dayOfWeek == d))|sort((a,b) => (a.openTime ? a.openTime|date('H:i') : '99:99') <=> (b.openTime ? b.openTime|date('H:i') : '99:99')) %}
          <div class="est-hours__row">
            <div class="est-hours__day">{{ labels[d] }}</div>
            <div class="est-hours__time">
              {% if intervals|length > 0 %}
                <div class="est-hours__slots">
                  {% for interval in intervals %}
                    <span class="est-hours__slot">{{ interval.openTime|date('H:i') }} - {{ interval.closeTime|date('H:i') }}</span>
                  {% endfor %}
                </div>
              {% else %}
                Fermé
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </section>

    <section class="account-card" id="reviews">
      <div class="account-card__header account-card__header--withAction">
        <div>
          <h2 class="account-card__title">Avis clients</h2>

          {% if reviewStats.count > 0 %}
            <div class="est-reviews__summary">
              {% include 'review/_stars.html.twig' with {
                rating: reviewStats.average,
                showValue: true
              } only %}
              <span class="est-reviews__summary-text">
                {{ reviewStats.count }} avis
              </span>
            </div>
          {% else %}
            <p class="est-muted">Aucun avis pour le moment.</p>
          {% endif %}
        </div>

        {% if reviewOpenParams %}
          <a class="btn btn--outline btn--md"
             href="{{ path('front_establishment_show', reviewOpenParams) }}">
            {{ ux_icon('uil:star') }}
            Laisser un avis
          </a>
        {% endif %}
      </div>

      {% if not reviewOpenParams and app.user %}
        <p class="est-hint">Tu pourras laisser un avis ici après une réservation passée dans cet établissement.</p>
      {% endif %}

      {% if establishmentReviews is empty %}
        <p class="est-muted">Cet établissement n’a pas encore reçu d’avis.</p>
      {% else %}
        <div class="est-review-list">
          {% for review in establishmentReviews %}
            <article class="est-review">
              <div class="est-review__head">
                <div>
                  <div class="est-review__author">
                    {{ review.client.firstName }}
                    {% if review.client.lastName %}
                      {{ review.client.lastName|first }}.
                    {% endif %}
                  </div>

                  {% include 'review/_stars.html.twig' with {
                    rating: review.rating,
                    class: 'review-stars--sm'
                  } only %}
                </div>

                <time class="est-review__date" datetime="{{ review.createdAt ? review.createdAt|date('c') : '' }}">
                  {{ review.createdAt ? review.createdAt|date('d/m/Y') : '' }}
                </time>
              </div>

              <p class="est-review__comment">{{ review.comment }}</p>

              {% if review.businessReply %}
                <div class="review-reply review-reply--business">
                  <div class="review-reply__head">
                    <div class="review-reply__author">{{ establishment.name }}</div>
                    {% if review.businessRepliedAt %}
                      <time class="review-reply__date" datetime="{{ review.businessRepliedAt|date('c') }}">
                        {{ review.businessRepliedAt|date('d/m/Y') }}
                      </time>
                    {% endif %}
                  </div>

                  <p class="review-reply__comment">{{ review.businessReply }}</p>
                </div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% endif %}
    </section>

    {# =========================
       BOOKING
       ========================= #}
    <section class="account-card" id="booking">
      <div class="account-card__header">
        <h2 class="account-card__title">Réserver un créneau</h2>
      </div>

      {% if openWeekDays|length == 0 %}
        <p class="est-muted">Aucune disponibilité réservable sur les prochaines semaines pour le moment.</p>
      {% else %}

        <div class="booking-block" id="booking-schedule">
          <div class="booking-label">Choisis un jour (jours ouverts uniquement)</div>

          <div class="booking-week">
            <a class="btn btn--outline btn--md booking-week__nav"
               href="{{ path('front_establishment_show', bookingBaseParams|merge({
                 service: selectedServiceId,
                 week: (weekStart|date_modify('-7 days'))|date('Y-m-d'),
                 professional: selectedProfessionalId ?: null
               })) }}">
              Semaine précédente
            </a>

            <div class="booking-days">
              {% for d in openWeekDays %}
                {% set dStr = d|date('Y-m-d') %}
                {% set isActiveDate = (selectedDateStr == dStr) %}

                <a class="day-btn {{ isActiveDate ? 'is-active' : '' }}"
                   href="{{ path('front_establishment_show', isActiveDate
                     ? bookingBaseParams|merge({
                         service: selectedServiceId,
                         week: weekStart|date('Y-m-d'),
                         professional: selectedProfessionalId ?: null
                       })
                     : bookingBaseParams|merge({
                         service: selectedServiceId,
                         week: weekStart|date('Y-m-d'),
                         date: dStr,
                         professional: selectedProfessionalId ?: null
                       })
                   ) }}">
                  <div class="day-btn__top">{{ d|date('d/m') }}</div>
                  <div class="day-btn__bot">{{ d|date('l')|replace({
                    'Monday':'Lun','Tuesday':'Mar','Wednesday':'Mer','Thursday':'Jeu','Friday':'Ven','Saturday':'Sam','Sunday':'Dim'
                  }) }}</div>
                </a>
              {% endfor %}
            </div>

            <a class="btn btn--outline btn--md booking-week__nav"
               href="{{ path('front_establishment_show', bookingBaseParams|merge({
                 service: selectedServiceId,
                 week: (weekStart|date_modify('+7 days'))|date('Y-m-d'),
                 professional: selectedProfessionalId ?: null
               })) }}">
              Semaine suivante
            </a>
          </div>
        </div>

        <div class="booking-block">
          <div class="booking-label">Choisis un professionnel</div>

          {% if professionalCandidates|length == 0 %}
            <p class="est-muted">Aucun professionnel disponible pour cet établissement.</p>
          {% else %}
            <div class="booking-slots">
              <a class="slot-btn {{ not selectedProfessionalId ? 'is-active' : '' }}"
                 href="{{ path('front_establishment_show', bookingBaseParams|merge({
                   service: selectedServiceId,
                   week: weekStart|date('Y-m-d'),
                   date: selectedDateStr ?: null,
                   time: selectedTime ?: null
                 })) }}">
                Indifférent
              </a>

              {% for professional in professionalCandidates %}
                <a class="slot-btn {{ selectedProfessionalId == professional.id ? 'is-active' : '' }}"
                   href="{{ path('front_establishment_show', bookingBaseParams|merge({
                     service: selectedServiceId,
                     week: weekStart|date('Y-m-d'),
                     date: selectedDateStr ?: null,
                     time: selectedTime ?: null,
                     professional: professional.id
                   })) }}">
                  {{ professional.firstName }} {{ professional.lastName }}
                </a>
              {% endfor %}
            </div>

            <p class="est-hint">
              En choisissant “Indifférent”, le système attribue d’abord un professionnel disponible, puis un admin pro ou le gérant si besoin.
            </p>
          {% endif %}
        </div>

        <div class="booking-block">
          <div class="booking-label">Choisis une heure</div>

          {% if not selectedServiceId %}
            <p class="est-muted">Sélectionne d’abord un service.</p>
          {% elseif not selectedDateStr %}
            <p class="est-muted">Sélectionne d’abord une date.</p>
          {% elseif slots|length == 0 %}
            <p class="est-muted">
              {% if selectedProfessional %}
                Aucun créneau disponible pour ce professionnel à cette date.
              {% else %}
                Aucun créneau disponible pour cette date.
              {% endif %}
            </p>
          {% else %}
            <div class="booking-slots">
              {% for s in slots %}
                {% set isActiveTime = (selectedTime == s.time) %}

                <a class="slot-btn {{ isActiveTime ? 'is-active' : '' }}"
                   href="{{ path('front_establishment_show', isActiveTime
                     ? bookingBaseParams|merge({
                         service: selectedServiceId,
                         week: weekStart|date('Y-m-d'),
                         date: selectedDateStr,
                         professional: selectedProfessionalId ?: null
                       })
                     : bookingBaseParams|merge({
                         service: selectedServiceId,
                         week: weekStart|date('Y-m-d'),
                         date: selectedDateStr,
                         time: s.time,
                         professional: selectedProfessionalId ?: null
                       })
                   ) }}">
                  {{ s.label }}
                </a>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <form method="post" action="{{ path('front_establishment_book', {id: establishment.id}) }}" class="booking-form">
          <input type="hidden" name="_token" value="{{ csrf_token('book_appointment') }}">
          <input type="hidden" name="service" value="{{ selectedServiceId }}">
          <input type="hidden" name="date" value="{{ selectedDateStr }}">
          <input type="hidden" name="time" value="{{ selectedTime }}">
          <input type="hidden" name="professional" value="{{ selectedProfessionalId }}">

          <button class="btn btn--primary btn--lg btn--block"
                  type="submit"
                  {% if not selectedServiceId or not selectedDateStr or not selectedTime %}disabled{% endif %}>
            Confirmer la réservation
          </button>

          <p class="est-muted est-center">
            La réservation est gratuite et peut être annulée jusqu’à 24h avant.
          </p>
        </form>

      {% endif %}
    </section>

    {% if reviewForm is not null and reviewModalAppointment is not null %}
      <div class="est-review-modal" role="dialog" aria-modal="true" aria-labelledby="review-modal-title">
        <div class="est-review-modal__backdrop">
          <a class="est-review-modal__scrim"
             href="{{ path('front_establishment_show', reviewBaseParams) }}"
             aria-label="Fermer"></a>

          <section class="est-review-modal__panel">
            <div class="est-review-modal__head">
              <h3 id="review-modal-title" class="est-review-modal__title">Laisser un avis</h3>

              <a class="est-review-modal__icon"
                 href="{{ path('front_establishment_show', reviewBaseParams) }}"
                 aria-label="Fermer">
                {{ ux_icon('uil:times') }}
              </a>
            </div>

            <div class="est-review-modal__meta">
              <div class="est-review-modal__establishment">{{ establishment.name }}</div>
              <div class="est-review-modal__address">{{ establishment.address }}, {{ establishment.postalCode }} {{ establishment.city }}</div>
              <div class="est-review-modal__service">
                {{ reviewModalAppointment.service ? reviewModalAppointment.service.name : 'Service réservé' }}
              </div>
            </div>

            {{ form_start(reviewForm, {
              action: path('app_review_create', { appointment: reviewModalAppointment.id }),
              attr: { class: 'review-form' }
            }) }}
              <input type="hidden" name="redirect_to" value="{{ path('front_establishment_show', reviewBaseParams) }}">

              <div class="review-form__field">
                <div class="review-form__label">{{ form_label(reviewForm.rating) }}</div>
                <div class="review-form__rating">
                  {% for choice in reviewForm.rating %}
                    {{ form_widget(choice, { attr: { class: 'review-form__star-input' } }) }}
                    <label class="review-form__star-label"
                           for="{{ choice.vars.id }}"
                           aria-label="{{ choice.vars.value }} étoiles">
                      &#9733;
                    </label>
                  {% endfor %}
                </div>
                {{ form_errors(reviewForm.rating) }}
              </div>

              <div class="review-form__field">
                {{ form_label(reviewForm.comment, null, { label_attr: { class: 'review-form__label' } }) }}
                {{ form_widget(reviewForm.comment) }}
                {{ form_errors(reviewForm.comment) }}
              </div>

              <div class="review-form__actions">
                <a class="btn btn--outline btn--md"
                   href="{{ path('front_establishment_show', reviewBaseParams) }}">
                  Annuler
                </a>

                <button class="btn btn--primary btn--md" type="submit">Soumettre</button>
              </div>
            {{ form_end(reviewForm) }}
          </section>
        </div>
      </div>
    {% endif %}

  </div>
{% endblock %}
