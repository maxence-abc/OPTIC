{% extends 'pro_dashboard/_layout.html.twig' %}

{% block title %}Calendrier professionnel{% endblock %}

{% block pro_content %}
  <section class="pro-calendar-page">
    <div class="mgr-pagehead pro-calendar-page__head">
      <div>
        <h1>Calendrier</h1>
        <p class="muted">Consultez votre planning, vos repos et les réservations de l’établissement.</p>
      </div>

      <div class="pro-calendar-page__switch">
        <a class="pro-calendar-page__switch-btn {% if selectedView == 'planning' %}is-active{% endif %}"
           href="{{ path('app_pro_calendar', { view: 'planning', date: anchorDate|date('Y-m-d') }) }}#pro-planning-view">
          Mon planning
        </a>
        <a class="pro-calendar-page__switch-btn {% if selectedView == 'calendar' %}is-active{% endif %}"
           href="{{ path('app_pro_calendar', { view: 'calendar', date: anchorDate|date('Y-m-d') }) }}#pro-calendar-reservations">
          Calendrier des réservations
        </a>
      </div>
    </div>

    {% if selectedView == 'planning' %}
      <div class="pro-planning-grid" id="pro-planning-view">
        <section class="mgr-card">
          <div class="pro-planning-section__head">
            <div>
              <h2>Aujourd’hui</h2>
              <p class="muted">Votre journée en cours et vos rendez-vous assignés.</p>
            </div>
            <span class="mgr-badge">{{ todayAppointmentsForProfessional|length }} rendez-vous</span>
          </div>

          <div class="pro-planning-today">
            <div class="pro-planning-today__block">
              <h3>Planning</h3>
              {% if todayScheduleEvents is empty and todayDefaultSchedules is empty %}
                <p class="muted">Aucun horaire de travail configuré aujourd’hui.</p>
              {% else %}
                <div class="pro-planning-events">
                  {% if todayScheduleEvents is empty and todayDefaultSchedules is not empty %}
                    <article class="pro-planning-event-card is-work">
                      <div class="pro-planning-event-card__title">Actif</div>
                      <div class="pro-planning-event-card__meta pro-planning-event-card__meta--stack">
                        {% for schedule in todayDefaultSchedules %}
                          <span>{{ schedule.displayRange }}</span>
                        {% endfor %}
                      </div>
                    </article>
                  {% endif %}

                  {% for event in todayScheduleEvents %}
                    <article class="pro-planning-event-card is-{{ event.type }}">
                      <div class="pro-planning-event-card__title">
                        {{ event.type == 'work' ? 'Actif' : event.displayTitle }}
                      </div>
                      <div class="pro-planning-event-card__meta">
                        {{ event.type == 'work' ? 'Horaire personnalisé' : event.typeLabel }}
                        {% if not event.isAllDay() %}
                          · {{ event.startTime ? event.startTime|date('H:i') : '' }} - {{ event.endTime ? event.endTime|date('H:i') : '' }}
                        {% endif %}
                      </div>
                    </article>
                  {% endfor %}
                </div>
              {% endif %}
            </div>

            <div class="pro-planning-today__block">
              <h3>Réservations</h3>
              {% if todayAppointmentsForProfessional is empty %}
                <p class="muted">Aucune réservation assignée aujourd’hui.</p>
              {% else %}
                <div class="pro-planning-appointments">
                  {% for appointment in todayAppointmentsForProfessional %}
                    <article class="pro-planning-appointment-card">
                      <div class="pro-planning-appointment-card__time">
                        {{ appointment.startTime ? appointment.startTime|date('H:i') : '--:--' }}
                      </div>
                      <div>
                        <strong>{{ appointment.client ? appointment.client.firstName ~ ' ' ~ appointment.client.lastName : 'Client' }}</strong>
                        <div class="muted">{{ appointment.service ? appointment.service.name : 'Service' }}</div>
                      </div>
                    </article>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </div>
        </section>

        <div class="mgr-planning-config-grid">
          <section class="mgr-card mgr-planning-sidecard">
            <div class="pro-planning-section__head">
              <div>
                <h2>Demander une exception</h2>
                <p class="muted">Soumettez un repos, un congé, une formation ou un horaire personnalisé au manager.</p>
              </div>
            </div>

            <div class="mgr-planning-sidecard__body">
              <p class="muted">Votre demande restera en attente tant qu’elle n’aura pas été acceptée. Une fois validée, elle sera intégrée à votre planning.</p>
              <a class="btn btn--dark" href="{{ path('app_pro_calendar', {
                view: 'planning',
                date: anchorDate|date('Y-m-d'),
                open_request: 1
              }) }}#pro-exception-request-modal">
                Faire une demande
              </a>
            </div>
          </section>

          <section class="mgr-card mgr-planning-sidecard">
            <div class="pro-planning-section__head">
              <div>
                <h2>Mes demandes</h2>
                <p class="muted">Suivez les demandes envoyées au manager et les motifs de décision.</p>
              </div>
            </div>

            <div class="mgr-planning-sidecard__body">
              {% if exceptionRequests is empty %}
                <div class="mgr-planning-sidecard__empty">
                  <strong>Aucune demande envoyée</strong>
                  <span>Vos prochaines demandes d’exception apparaîtront ici avec leur statut.</span>
                </div>
              {% else %}
                <div class="mgr-planning-sidecard__list">
                  {% for requestEvent in exceptionRequests %}
                    {% set statusClass = requestEvent.isApproved ? 'mgr-badge--ok' : (requestEvent.isRejected ? 'mgr-badge--danger' : 'mgr-badge--muted') %}
                    <article class="mgr-planning-sidecard__item">
                      <div class="mgr-planning-sidecard__item-top">
                        <span class="mgr-planning-pill is-{{ requestEvent.type }}">{{ requestEvent.type == 'work' ? 'Horaire personnalisé' : requestEvent.typeLabel }}</span>
                        <span class="mgr-badge {{ statusClass }}">{{ requestEvent.statusLabel }}</span>
                      </div>
                      <div class="mgr-planning-sidecard__item-meta">
                        <span>
                          Du {{ requestEvent.startDate ? requestEvent.startDate|date('d/m/Y') : '' }}
                          {% if requestEvent.endDate and requestEvent.endDate|date('Y-m-d') != requestEvent.startDate|date('Y-m-d') %}
                            au {{ requestEvent.endDate|date('d/m/Y') }}
                          {% endif %}
                        </span>
                        {% if not requestEvent.isAllDay() %}
                          <span>{{ requestEvent.startTime ? requestEvent.startTime|date('H:i') : '' }} - {{ requestEvent.endTime ? requestEvent.endTime|date('H:i') : '' }}</span>
                        {% endif %}
                        {% if requestEvent.notes %}
                          <span>Motif demandé : {{ requestEvent.notes }}</span>
                        {% endif %}
                        <span>Envoyée le {{ requestEvent.createdAt ? requestEvent.createdAt|date('d/m/Y H:i') : '' }}</span>
                        {% if requestEvent.reviewedAt %}
                          <span>Décision le {{ requestEvent.reviewedAt|date('d/m/Y H:i') }}</span>
                        {% endif %}
                        {% if requestEvent.decisionReason %}
                          <span>
                            {{ requestEvent.isRejected ? 'Motif du refus' : 'Motif de décision' }} : {{ requestEvent.decisionReason }}
                          </span>
                        {% endif %}
                      </div>
                    </article>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </section>
        </div>

        <section class="mgr-card pro-week-shell" id="pro-week-shell">
          <div class="pro-planning-section__head">
            <div>
              <h2>Semaine en cours</h2>
              <p class="muted">Vision rapide de vos horaires, repos et réservations.</p>
            </div>

            <div class="mgr-planning-nav">
              <a class="mgr-planning-nav__btn" href="{{ path('app_pro_calendar', {
                view: 'planning',
                date: anchorDate|date_modify('-7 days')|date('Y-m-d')
              }) }}#pro-week-shell">
                {{ ux_icon('uil:angle-left') }}
              </a>
              <span class="mgr-planning-nav__label">{{ planningWeekStart|date('d/m') }} - {{ planningWeekEnd|date('d/m') }}</span>
              <a class="mgr-planning-nav__btn" href="{{ path('app_pro_calendar', {
                view: 'planning',
                date: anchorDate|date_modify('+7 days')|date('Y-m-d')
              }) }}#pro-week-shell">
                {{ ux_icon('uil:angle-right') }}
              </a>
            </div>
          </div>

          <div class="pro-week-strip">
            <div class="pro-week-grid">
              {% for day in weeklyPlanningDays %}
                <article class="pro-week-card {{ day.summary.class }}">
                  <div class="pro-week-card__head">
                    <div>
                      <div class="pro-week-card__day">{{ calendarWeekDays[loop.index0].label }}</div>
                      <div class="pro-week-card__date">{{ day.date|date('d/m') }}</div>
                    </div>
                    <span class="pro-week-card__badge">{{ day.summary.label }}</span>
                  </div>

                  <div class="pro-week-card__section">
                    <div class="pro-week-card__section-label">Planning</div>

                    {% if day.events is not empty %}
                      <div class="pro-week-card__sub">{{ day.summary.sublabel }}</div>
                      <div class="pro-week-card__list">
                        {% for event in day.events %}
                          <div class="pro-week-card__line">
                            <span>{{ event.type == 'work' ? 'Horaire personnalisé' : event.displayTitle }}</span>
                            {% if not event.isAllDay() %}
                              <span>{{ event.startTime ? event.startTime|date('H:i') : '' }} - {{ event.endTime ? event.endTime|date('H:i') : '' }}</span>
                            {% endif %}
                          </div>
                        {% endfor %}
                      </div>
                    {% elseif day.defaultSchedules is not empty %}
                      <div class="pro-week-card__substack">
                        {% for schedule in day.defaultSchedules %}
                          <span class="pro-week-card__subline">{{ schedule.displayRange }}</span>
                        {% endfor %}
                      </div>
                    {% else %}
                      <div class="pro-week-card__sub">{{ day.summary.sublabel }}</div>
                      <div class="pro-week-card__empty">Aucun horaire spécifique</div>
                    {% endif %}
                  </div>

                  <div class="pro-week-card__section pro-week-card__section--appointments">
                    <div class="pro-week-card__section-label">Réservations</div>

                    {% if day.appointments is not empty %}
                      <div class="pro-week-card__appointment-list">
                        {% for appointment in day.appointments|slice(0, 3) %}
                          <div class="pro-week-card__appointment-item">
                            <span>{{ appointment.startTime ? appointment.startTime|date('H:i') : '--:--' }}</span>
                            <span>{{ appointment.client ? appointment.client.firstName ~ ' ' ~ appointment.client.lastName : 'Client' }}</span>
                          </div>
                        {% endfor %}

                        {% if day.appointments|length > 3 %}
                          <div class="pro-week-card__more">
                            + {{ day.appointments|length - 3 }} autre{{ day.appointments|length - 3 > 1 ? 's' : '' }}
                          </div>
                        {% endif %}
                      </div>
                    {% else %}
                      <div class="pro-week-card__empty">Aucun rendez-vous assigné</div>
                    {% endif %}
                  </div>
                </article>
              {% endfor %}
            </div>
          </div>
        </section>
      </div>
    {% else %}
      <div id="pro-calendar-reservations">
        <twig:ProReservationCalendar establishmentId="{{ establishment.id }}" />
      </div>
    {% endif %}
  </section>

  {% if openRequestModal %}
    <div class="mgr-planning-modal" id="pro-exception-request-modal">
      <div class="mgr-planning-modal__backdrop">
        <a class="mgr-planning-modal__close" href="{{ path('app_pro_calendar', {
          view: 'planning',
          date: anchorDate|date('Y-m-d')
        }) }}"></a>

        <section class="mgr-planning-modal__panel">
          <div class="mgr-planning-modal__head">
            <div>
              <h2>Demander une exception</h2>
              <p class="muted">Décrivez votre besoin. Le manager devra accepter ou refuser la demande avec un motif.</p>
            </div>
          </div>

          {{ form_start(requestForm, {
            action: path('app_pro_calendar', {
              view: 'planning',
              date: anchorDate|date('Y-m-d'),
              open_request: 1
            })
          }) }}
            {{ form_errors(requestForm) }}

            <div class="mgr-planning-modal__grid">
              <div class="mgr-planning-modal__field mgr-planning-modal__field--full">
                {{ form_label(requestForm.type) }}
                {{ form_widget(requestForm.type) }}
                {{ form_errors(requestForm.type) }}
              </div>

              <div class="mgr-planning-modal__field">
                {{ form_label(requestForm.startDate) }}
                {{ form_widget(requestForm.startDate) }}
                {{ form_errors(requestForm.startDate) }}
              </div>

              <div class="mgr-planning-modal__field">
                {{ form_label(requestForm.endDate) }}
                {{ form_widget(requestForm.endDate) }}
                {{ form_errors(requestForm.endDate) }}
              </div>

              <div class="mgr-planning-modal__field">
                {{ form_label(requestForm.startTime) }}
                {{ form_widget(requestForm.startTime) }}
                {{ form_errors(requestForm.startTime) }}
              </div>

              <div class="mgr-planning-modal__field">
                {{ form_label(requestForm.endTime) }}
                {{ form_widget(requestForm.endTime) }}
                {{ form_errors(requestForm.endTime) }}
              </div>

              <div class="mgr-planning-modal__field mgr-planning-modal__field--full">
                {{ form_label(requestForm.notes) }}
                {{ form_widget(requestForm.notes) }}
                {{ form_errors(requestForm.notes) }}
              </div>
            </div>

            <div class="mgr-planning-modal__actions">
              <a class="btn btn--outline" href="{{ path('app_pro_calendar', {
                view: 'planning',
                date: anchorDate|date('Y-m-d')
              }) }}">Annuler</a>
              <button class="btn btn--dark" type="submit">Envoyer la demande</button>
            </div>
          {{ form_end(requestForm) }}
        </section>
      </div>
    </div>
  {% endif %}
{% endblock %}
