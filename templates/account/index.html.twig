{% extends 'base.html.twig' %}

{% block title %}Mon compte - OPTIC{% endblock %}
{% block body_class %}page-account{% endblock %}

{% block stylesheets %}
  <link rel="stylesheet" href="/css/pages/account.css">
{% endblock %}

{# Désactive la navbar uniquement sur /account #}
{% block header %}{% endblock %}

{% block body %}

{% set activeTab = app.request.query.get('tab') ?: 'reservations' %}

{# HERO #}
<section class="account-hero">
  <div class="container container--wide account-hero__container">
    <a class="account-hero__back" href="{{ path('app_home') }}">
      <span class="account-hero__back-icon" aria-hidden="true">
        {{ ux_icon('uil:arrow-left') }}
      </span>
      Retour
    </a>

    <div class="account-hero__identity">
      <div class="account-hero__avatar" aria-hidden="true">
        <span class="account-hero__avatar-icon" aria-hidden="true">{{ ux_icon('uil:user') }}</span>
      </div>

      <div class="account-hero__text">
        <div class="account-hero__title">Mon Compte Client</div>
        <div class="account-hero__email">{{ app.user.email }}</div>
      </div>
    </div>
  </div>
</section>

{# CONTENT #}
<section class="account">
  <div class="container container--wide account__container">

    {# TABS (liens, stable) #}
    <div class="account-tabs" role="tablist" aria-label="Onglets compte">

      <a
        class="account-tabs__tab {{ activeTab == 'reservations' ? 'is-active' : '' }}"
        href="{{ path('app_account', { tab: 'reservations' }) }}"
        role="tab"
        aria-selected="{{ activeTab == 'reservations' ? 'true' : 'false' }}"
      >
        <span class="account-tabs__icon" aria-hidden="true">{{ ux_icon('uil:calendar-alt') }}</span>
        Mes réservations
      </a>

      <a
        class="account-tabs__tab {{ activeTab == 'reviews' ? 'is-active' : '' }}"
        href="{{ path('app_account', { tab: 'reviews' }) }}"
        role="tab"
        aria-selected="{{ activeTab == 'reviews' ? 'true' : 'false' }}"
      >
        <span class="account-tabs__icon" aria-hidden="true">{{ ux_icon('uil:star') }}</span>
        Mes avis
      </a>

      <a
        class="account-tabs__tab {{ activeTab == 'profile' ? 'is-active' : '' }}"
        href="{{ path('app_account', { tab: 'profile' }) }}"
        role="tab"
        aria-selected="{{ activeTab == 'profile' ? 'true' : 'false' }}"
      >
        <span class="account-tabs__icon" aria-hidden="true">{{ ux_icon('uil:setting') }}</span>
        Profil
      </a>

    </div>

    {# PANELS #}
    <div class="account-panels">

      {# ===================== RÉSERVATIONS ===================== #}
      {% if activeTab == 'reservations' %}
        <div class="account-panel is-active" role="tabpanel" id="account-reservations">

          {# RÉSERVATIONS À VENIR (cards à l'intérieur de la même account-card) #}
          <div class="account-card">
            <div class="account-card__header">
              <h2 class="account-card__title">
                Réservations à venir ({{ upcomingAppointments|default([])|length }})
              </h2>
            </div>

            {% if upcomingAppointments is defined and upcomingAppointments is not empty %}
              <div class="reservation-list">
                {% for a in upcomingAppointments %}
                  {% include 'account/_reservation_card.html.twig' with { appointment: a } %}
                {% endfor %}
              </div>
            {% else %}
              <p class="account-muted">Aucune réservation à venir pour le moment.</p>
            {% endif %}
          </div>

          {# HISTORIQUE #}
          <div class="account-card account-card--spaced">
            <div class="account-card__header">
              <h2 class="account-card__title">Réservation passée </h2>
            </div>

            {% if pastAppointments is defined and pastAppointments is not empty %}
              <div class="reservation-list reservation-list--compact">
                {% for a in pastAppointments %}
                  {% include 'account/_reservation_card.html.twig' with { appointment: a, compact: true } %}
                {% endfor %}
              </div>
            {% else %}
              <p class="account-muted">Aucun historique pour le moment.</p>
            {% endif %}
          </div>

        </div>
      {% endif %}

      {# ===================== AVIS ===================== #}
      {% if activeTab == 'reviews' %}
        <div class="account-panel is-active" role="tabpanel">
          <div class="account-card">
            <div class="account-card__header">
              <h2 class="account-card__title">Réservations à évaluer</h2>
              <span class="account-badge account-badge--neutral">{{ reviewableAppointments|length }} en attente</span>
            </div>

            {% if reviewableAppointments is empty %}
              <p class="account-muted">Aucun avis à laisser pour le moment.</p>
            {% else %}
              <div class="account-list">
                {% for appointment in reviewableAppointments %}
                  {% set service = appointment.service %}
                  {% set establishment = service ? service.establishment : null %}

                  {% if establishment %}
                    <div class="account-list__item account-list__item--reviewable">
                      <div>
                        <div class="account-list__title">{{ establishment.name }}</div>
                        <div class="account-list__meta">
                          <span>{{ service ? service.name : 'Service' }}</span>
                          <span>{{ appointment.date ? appointment.date|date('d/m/Y') : 'Date indisponible' }}</span>
                          {% if appointment.startTime %}
                            <span>{{ appointment.startTime|date('H:i') }}</span>
                          {% endif %}
                        </div>
                      </div>

                      <div class="account-list__actions">
                        <a class="btn btn--primary"
                           href="{{ path('front_establishment_show', {
                             id: establishment.id,
                             review: appointment.id,
                             _fragment: 'reviews'
                           }) }}">
                          Laisser un avis
                        </a>
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>

          <div class="account-card">
            <div class="account-card__header">
              <h2 class="account-card__title">Avis publiés</h2>
              <span class="account-badge account-badge--neutral">{{ clientReviews|length }} avis</span>
            </div>

            {% if clientReviews is empty %}
              <p class="account-muted">Vous n’avez encore publié aucun avis.</p>
            {% else %}
              <div class="account-review-list">
                {% for review in clientReviews %}
                  <article class="account-review">
                    <div class="account-review__top">
                      <div>
                        <h3 class="account-review__title">{{ review.establishment.name }}</h3>
                        <div class="account-list__meta">
                          <span>{{ review.appointment and review.appointment.service ? review.appointment.service.name : 'Service' }}</span>
                          <span>{{ review.createdAt ? review.createdAt|date('d/m/Y') : '' }}</span>
                        </div>
                      </div>

                      {% include 'review/_stars.html.twig' with {
                        rating: review.rating,
                        class: 'review-stars--sm'
                      } only %}
                    </div>

                    <p class="account-review__comment">{{ review.comment }}</p>

                    {% if review.businessReply %}
                      <div class="review-reply review-reply--business">
                        <div class="review-reply__head">
                          <div class="review-reply__author">{{ review.establishment.name }}</div>
                          {% if review.businessRepliedAt %}
                            <time class="review-reply__date" datetime="{{ review.businessRepliedAt|date('c') }}">
                              {{ review.businessRepliedAt|date('d/m/Y') }}
                            </time>
                          {% endif %}
                        </div>

                        <p class="review-reply__comment">{{ review.businessReply }}</p>
                      </div>
                    {% endif %}

                    <a class="account-review__link"
                       href="{{ path('front_establishment_show', {
                         id: review.establishment.id,
                         _fragment: 'reviews'
                       }) }}">
                      Voir l’établissement
                    </a>
                  </article>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {# ===================== PROFIL ===================== #}
      {% if activeTab == 'profile' %}
        <div class="account-panel is-active" role="tabpanel" id="account-profile">

          <div class="account-card">
            <div class="account-card__header account-card__header--withAction">
              <h2 class="account-card__title">Informations personnelles</h2>

              {% if not editProfile %}
                <twig:Button
                  label="Modifier"
                  href="{{ path('app_account', { tab: 'profile', edit: 1 }) }}#account-profile"
                  variant="outline"
                  size="sm"
                  iconLeft="uil:edit"
                />
              {% endif %}
            </div>

            {% if editProfile and profileForm is not null %}
              {{ form_start(profileForm, {
                action: path('app_account', { tab: 'profile', edit: 1 }) ~ '#account-profile',
                attr: { class: 'account-profile-form' }
              }) }}
                <div class="account-form-grid">
                  <div class="account-form-field">
                    {{ form_label(profileForm.firstName) }}
                    {{ form_widget(profileForm.firstName, { attr: { class: 'account-input' } }) }}
                    {{ form_errors(profileForm.firstName) }}
                  </div>

                  <div class="account-form-field">
                    {{ form_label(profileForm.lastName) }}
                    {{ form_widget(profileForm.lastName, { attr: { class: 'account-input' } }) }}
                    {{ form_errors(profileForm.lastName) }}
                  </div>

                  <div class="account-form-field">
                    {{ form_label(profileForm.email) }}
                    {{ form_widget(profileForm.email, { attr: { class: 'account-input' } }) }}
                    {{ form_errors(profileForm.email) }}
                  </div>

                  <div class="account-form-field">
                    {{ form_label(profileForm.phone) }}
                    {{ form_widget(profileForm.phone, { attr: { class: 'account-input' } }) }}
                    {{ form_errors(profileForm.phone) }}
                  </div>
                </div>

                <div class="account-form-actions">
                  <twig:Button
                    label="Enregistrer"
                    type="submit"
                    variant="primary"
                    size="sm"
                  />

                  <twig:Button
                    label="Annuler"
                    href="{{ path('app_account', { tab: 'profile' }) }}#account-profile"
                    variant="outline"
                    size="sm"
                  />
                </div>
              {{ form_end(profileForm) }}
            {% else %}
              <div class="account-kv">
                <div class="account-kv__row">
                  <div class="account-kv__key">Nom complet</div>
                  <div class="account-kv__value">{{ app.user.firstName }} {{ app.user.lastName }}</div>
                </div>

                <div class="account-kv__row">
                  <div class="account-kv__key">Email</div>
                  <div class="account-kv__value">{{ app.user.email }}</div>
                </div>

                <div class="account-kv__row">
                  <div class="account-kv__key">Téléphone</div>
                  <div class="account-kv__value">{{ app.user.phone ?: '—' }}</div>
                </div>
              </div>
            {% endif %}
          </div>

          <div class="account-card" id="account-settings">
            <div class="account-card__header">
              <h2 class="account-card__title">Sécurité</h2>
            </div>

            <twig:Button
              label="Changer le mot de passe"
              href="{{ path('app_forgot_password_request') }}"
              variant="outline"
              size="md"
              iconLeft="uil:lock"
            />
          </div>

          <div class="account-card">
            <div class="account-card__header">
              <h2 class="account-card__title">Préférences</h2>
            </div>

            <div class="account-checks">
              <label class="account-check">
                <input type="checkbox">
                <span>Recevoir des notifications par email</span>
              </label>

              <label class="account-check">
                <input type="checkbox">
                <span>Recevoir des offres promotionnelles</span>
              </label>

              <label class="account-check">
                <input type="checkbox">
                <span>Rappels de réservation par SMS</span>
              </label>
            </div>
          </div>

          <div class="account-logout">
            <a class="account-logout__btn" href="{{ path('app_logout') }}">
              <span class="account-logout__icon" aria-hidden="true">{{ ux_icon('uil:signout') }}</span>
              Se déconnecter
            </a>
          </div>

        </div>
      {% endif %}

    </div>
  </div>
</section>

{% endblock %}
